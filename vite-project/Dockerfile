FROM node:22-alpine

WORKDIR /app

# package*.json — означает: скопируй все файлы, которые начинаются с package и заканчиваются на .json.
# ./ — означает “в текущую папку внутри контейнера”.
COPY package*.json ./ 

RUN npm i

# первая точка означает “возьми всё из текущей папки на моём компьютере”
# вторая точка означает “положи в текущую папку внутри контейнера” (/app)
COPY . . 

# EXPOSE — говорит: приложение внутри контейнера работает на порту 5173.
EXPOSE 5173

# npm — запускаем npm.

# run — говорим npm: запусти скрипт из package.json.

# dev — имя скрипта:

# -- — специальный разделитель. Он говорит npm: “всё, что после этого, передай внутрь команды”.

# --host — параметр для Vite. Он нужен, чтобы сайт был доступен снаружи контейнера.
CMD ["npm", "run", "dev", "--" ,"--host"]
